{
  "name": "launchguard-rn",
  "version": "0.2.0",
  "description": "Launch-readiness scanner for React Native/Expo apps covering security, databases, crashes, privacy, and store-readiness.",
  "bin": { "launchguard-rn": "dist/index.js" },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "scan": "tsx src/index.ts .",
    "check": "npm run build"
  },
  "keywords": ["react-native", "expo", "security", "firebase", "supabase", "appwrite", "mobile", "scanner", "cli", "play-store"],
  "author": "Sahil Sharma",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
